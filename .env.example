# =============================================================================
# SafeguardJunub / Taban — Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values.

# --- Mode ---
# Set to "false" for production (no demo data, no demo account buttons).
# When "true" or omitted, seeds demo patients/hospitals/users for testing.
NEXT_PUBLIC_DEMO_MODE=true

# --- Production Setup (only used when DEMO_MODE=false) ---
# Initial admin credentials (created on first run)
NEXT_PUBLIC_ADMIN_NAME=System Administrator
NEXT_PUBLIC_ADMIN_PASSWORD=Admin@Taban2026!

# Organization details
NEXT_PUBLIC_ORG_NAME=My Organization
NEXT_PUBLIC_ORG_EMAIL=admin@organization.org
NEXT_PUBLIC_ORG_COUNTRY=South Sudan

# --- Auth ---
# JWT secret for session tokens. MUST be set in production.
# Generate with: openssl rand -base64 48
NEXT_PUBLIC_JWT_SECRET=change-me-to-a-random-secret

# --- CouchDB Sync ---
# Set to "true" to enable PouchDB <-> CouchDB live replication.
# When "false" the app works fully offline with local PouchDB only.
NEXT_PUBLIC_SYNC_ENABLED=false

# CouchDB server URL (include credentials for authenticated access)
# Example: http://admin:password@localhost:5984
NEXT_PUBLIC_COUCHDB_URL=http://localhost:5984

# Optional: CouchDB admin credentials (used by setup script & API routes)
COUCHDB_ADMIN_USER=admin
COUCHDB_ADMIN_PASSWORD=

# --- PostgreSQL (National Analytics Database) ---
# Used server-side only — never exposed to the browser.
DATABASE_URL=postgresql://taban:password@localhost:5432/safeguard_junub
