# =============================================================================
# SafeguardJunub / Taban — Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values.

# --- CouchDB Sync ---
# Set to "true" to enable PouchDB ↔ CouchDB live replication.
# When "false" the app works fully offline with local PouchDB only.
NEXT_PUBLIC_SYNC_ENABLED=false

# CouchDB server URL (include credentials for authenticated access)
# Example: http://admin:password@localhost:5984
NEXT_PUBLIC_COUCHDB_URL=http://localhost:5984

# Optional: CouchDB admin credentials (used by setup script & API routes)
COUCHDB_ADMIN_USER=admin
COUCHDB_ADMIN_PASSWORD=

# --- PostgreSQL (National Analytics Database) ---
# Used server-side only — never exposed to the browser.
DATABASE_URL=postgresql://taban:password@localhost:5432/safeguard_junub

# --- Auth ---
# JWT secret for session tokens (generate a strong random value)
JWT_SECRET=change-me-to-a-random-secret

